# Purpose: Ignore local environment files, caches, build output, and secrets.

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
backend/.venv/

# Node
node_modules/
frontend/node_modules/
frontend/dist/

# Environment and secrets
.env
backend/.env
frontend/.env

# IDE and OS
.vscode/*
!.vscode/tasks.json
.DS_Store
Thumbs.db

# Logs
*.log
