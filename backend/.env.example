# Purpose: Example environment variables for local backend configuration.
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql+psycopg2://ai_car_user:ai_car_pass@localhost:5432/ai_car_sales

# AI Model Configuration
MODEL_PROVIDER=groq
MODEL_NAME=llama-3.3-70b-versatile
GROQ_API_KEY=replace_with_real_key

# Showroom Details
SHOWROOM_LOCATION="Seoul Kia Showroom"
